# Provider-API-Keys für llmux. Kopiere diese Datei nach `.env` und trage die
# benötigten Keys ein. Welche Env-Variable ein Provider erwartet, legt das Feld
# `api_key_env` (bzw. `keys[].env`) in config/llmux.yaml fest.
#
# Nur die Provider eintragen, die in der Config aktiviert sind — der Rest kann leer
# bleiben. Lokale Provider (z. B. Ollama) brauchen keinen Key.

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optionaler Gateway-Key: ist `auth.llmux_key` in der Config gesetzt, müssen Clients
# ihn als `Authorization: Bearer <key>` mitschicken.
# LLMUX_KEY=
