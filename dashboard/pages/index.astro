---
import {
  Activity,
  AlertTriangle,
  Boxes,
  BrainCircuit,
  CheckCircle2,
  ChevronRight,
  CircleDollarSign,
  Clock3,
  DatabaseZap,
  Gauge,
  LayoutDashboard,
  LockKeyhole,
  Network,
  Radar,
  Route,
  Search,
  Settings2,
  ShieldCheck,
  SlidersHorizontal,
  TerminalSquare,
  Zap,
} from '@lucide/astro';
import '../styles/app.css';
import { budgetSeries, modelMatrix, overview, policySignals, projectRows, routeFeed } from '../data/dashboard';

const nav = [
  { label: 'Overview', icon: LayoutDashboard, active: true },
  { label: 'Live', icon: Activity },
  { label: 'Policy', icon: ShieldCheck },
  { label: 'Models', icon: Boxes },
  { label: 'Projects', icon: Network },
  { label: 'Costs', icon: CircleDollarSign },
  { label: 'Diagnostics', icon: TerminalSquare },
  { label: 'Settings', icon: Settings2 },
];

const statusClasses = {
  allowed: 'text-success bg-success/8',
  degraded: 'text-warning bg-warning/8',
  cached: 'text-accent bg-accent/8',
  fallback: 'text-info bg-info/8',
  rejected: 'text-error bg-error/8',
  forced: 'text-muted bg-surface-2',
};

const toneClasses = {
  success: 'text-success',
  warning: 'text-warning',
  error: 'text-error',
  info: 'text-info',
};

const maxBudget = Math.max(...budgetSeries);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="llmux local LLM routing control room" />
    <title>llmux Control Room</title>
  </head>
  <body>
    <div class="min-h-screen lg:grid lg:grid-cols-[72px_minmax(0,1fr)]">
      <aside class="hidden border-e border-border/70 bg-bg/78 backdrop-blur-xl lg:flex lg:min-h-screen lg:flex-col lg:items-center lg:py-4">
        <a class="focus-ring mb-6 flex size-11 items-center justify-center rounded-lg border border-accent/35 bg-accent/10 text-accent" href="/" aria-label="llmux overview">
          <Route size={22} stroke-width={2.2} />
        </a>
        <nav class="flex flex-1 flex-col items-center gap-2" aria-label="Primary">
          {nav.map((item) => {
            const Icon = item.icon;
            return (
              <a
                class:list={[
                  'focus-ring group relative flex size-11 items-center justify-center rounded-lg border transition',
                  item.active
                    ? 'border-accent/40 bg-accent/12 text-accent'
                    : 'border-transparent text-muted hover:border-border hover:bg-surface hover:text-text',
                ]}
                href="#"
                aria-label={item.label}
              >
                <Icon size={20} />
                <span class="pointer-events-none absolute start-13 z-20 hidden whitespace-nowrap rounded-md border border-border bg-bg-raised px-2 py-1 text-xs text-text shadow-xl group-hover:block">
                  {item.label}
                </span>
              </a>
            );
          })}
        </nav>
      </aside>

      <main class="min-w-0">
        <header class="sticky top-0 z-10 border-b border-border/70 bg-bg/74 px-4 py-3 backdrop-blur-xl sm:px-6 lg:px-8">
          <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex items-center gap-3">
              <div class="flex size-10 items-center justify-center rounded-lg border border-accent/35 bg-accent/10 text-accent lg:hidden">
                <Route size={21} />
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <h1 class="text-xl font-semibold tracking-normal text-text">llmux Control Room</h1>
                  <span class="chip border-success/35 bg-success/8 text-success">
                    <span class="size-1.5 rounded-full bg-success"></span>
                    {overview.status}
                  </span>
                </div>
                <p class="mt-1 text-sm text-muted">Local policy, routing, cost and model telemetry.</p>
              </div>
            </div>

            <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
              <label class="focus-within:border-accent/45 flex h-10 min-w-0 items-center gap-2 rounded-lg border border-border bg-surface px-3 text-muted transition sm:w-80">
                <Search size={17} />
                <input class="min-w-0 flex-1 border-0 bg-transparent text-sm text-text outline-none placeholder:text-faint" placeholder="Search requests, models, projects" />
              </label>
              <button class="focus-ring inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-border bg-surface px-3 text-sm text-text transition hover:border-accent/35 hover:bg-surface-2">
                <SlidersHorizontal size={17} />
                Filters
              </button>
            </div>
          </div>
        </header>

        <div class="px-4 py-4 sm:px-6 lg:px-8">
          <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-5" aria-label="Overview metrics">
            <article class="panel rounded-lg p-4">
              <div class="flex items-center justify-between text-sm text-muted">
                <span>Requests/min</span>
                <Activity size={17} class="text-accent" />
              </div>
              <div class="metric-value mt-3 text-3xl font-semibold">{overview.requestsPerMinute}</div>
              <p class="mt-1 text-xs text-muted">+14% from last hour</p>
            </article>
            <article class="panel rounded-lg p-4">
              <div class="flex items-center justify-between text-sm text-muted">
                <span>Today cost</span>
                <CircleDollarSign size={17} class="text-success" />
              </div>
              <div class="metric-value mt-3 text-3xl font-semibold">${overview.todayCost.toFixed(2)}</div>
              <p class="mt-1 text-xs text-muted">daily cap $2.00</p>
            </article>
            <article class="panel rounded-lg p-4">
              <div class="flex items-center justify-between text-sm text-muted">
                <span>Budget used</span>
                <Gauge size={17} class="text-warning" />
              </div>
              <div class="metric-value mt-3 text-3xl font-semibold">{overview.budgetUsed}%</div>
              <div class="mt-3 h-1.5 rounded-full bg-bg-raised">
                <div class="h-full rounded-full bg-warning" style={`width: ${overview.budgetUsed}%`}></div>
              </div>
            </article>
            <article class="panel rounded-lg p-4">
              <div class="flex items-center justify-between text-sm text-muted">
                <span>Cache hit rate</span>
                <DatabaseZap size={17} class="text-accent" />
              </div>
              <div class="metric-value mt-3 text-3xl font-semibold">{overview.cacheHitRate}%</div>
              <p class="mt-1 text-xs text-muted">exact match cache</p>
            </article>
            <article class="panel rounded-lg p-4 sm:col-span-2 xl:col-span-1">
              <div class="flex items-center justify-between text-sm text-muted">
                <span>p95 latency</span>
                <Clock3 size={17} class="text-info" />
              </div>
              <div class="metric-value mt-3 text-3xl font-semibold">{(overview.p95Latency / 1000).toFixed(2)}s</div>
              <p class="mt-1 text-xs text-muted">provider responses</p>
            </article>
          </section>

          <section class="mt-4 grid gap-4 2xl:grid-cols-[minmax(0,1.35fr)_minmax(360px,0.65fr)]">
            <div class="panel overflow-hidden rounded-lg">
              <div class="flex flex-col gap-3 border-b border-border/70 p-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <h2 class="text-base font-semibold">Live route feed</h2>
                  <p class="mt-1 text-sm text-muted">Recent routing decisions with policy and provider outcomes.</p>
                </div>
                <button class="focus-ring inline-flex h-9 items-center justify-center gap-2 rounded-lg bg-accent px-3 text-sm font-medium text-bg transition hover:bg-accent/88">
                  <Zap size={16} />
                  Inspect live
                </button>
              </div>

              <div class="scrollbar-subtle overflow-x-auto">
                <table class="w-full min-w-[920px] border-collapse text-sm">
                  <thead class="bg-bg-raised/70 text-xs uppercase text-faint">
                    <tr>
                      <th class="px-4 py-3 text-start font-medium">Time</th>
                      <th class="px-4 py-3 text-start font-medium">Tool / Project</th>
                      <th class="px-4 py-3 text-start font-medium">Task</th>
                      <th class="px-4 py-3 text-start font-medium">Selected model</th>
                      <th class="px-4 py-3 text-start font-medium">Cost</th>
                      <th class="px-4 py-3 text-start font-medium">Latency</th>
                      <th class="px-4 py-3 text-start font-medium">Policy</th>
                      <th class="px-4 py-3 text-end font-medium">Open</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-border/60">
                    {routeFeed.map((row, index) => (
                      <tr class="group transition hover:bg-surface-2/70" data-request-row data-request={JSON.stringify(row)}>
                        <td class="metric-value px-4 py-3 text-muted">{row.time}</td>
                        <td class="px-4 py-3">
                          <div class="font-medium text-text">{row.tool}</div>
                          <div class="text-xs text-muted">{row.project}</div>
                        </td>
                        <td class="px-4 py-3">
                          <span class="rounded-md border border-border bg-bg-raised px-2 py-1 font-mono text-xs text-muted">{row.task}</span>
                        </td>
                        <td class="px-4 py-3">
                          <div class="font-medium text-text">{row.model}</div>
                          <div class="text-xs text-muted">tier {row.tier || '-'}</div>
                        </td>
                        <td class="metric-value px-4 py-3">{row.cost}</td>
                        <td class="metric-value px-4 py-3 text-muted">{row.latency}</td>
                        <td class="px-4 py-3">
                          <div class="flex flex-wrap gap-1.5">
                            <span class:list={['chip capitalize', statusClasses[row.status]]}>{row.status}</span>
                            {row.chips.map((chip) => <span class="chip border-border bg-bg-raised text-muted">{chip}</span>)}
                          </div>
                        </td>
                        <td class="px-4 py-3 text-end">
                          <button class="focus-ring inline-flex size-8 items-center justify-center rounded-lg border border-border bg-surface text-muted transition hover:border-accent/35 hover:text-accent" data-open-inspector aria-label={`Inspect request ${index + 1}`}>
                            <ChevronRight size={16} />
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <aside class="grid gap-4">
              <section class="panel rounded-lg p-4">
                <div class="mb-4 flex items-center justify-between">
                  <div>
                    <h2 class="text-base font-semibold">Policy radar</h2>
                    <p class="mt-1 text-sm text-muted">Decision outcomes today.</p>
                  </div>
                  <Radar size={20} class="text-accent" />
                </div>
                <div class="grid gap-2">
                  {policySignals.map((signal) => (
                    <div class="flex items-center justify-between rounded-lg border border-border/60 bg-bg-raised px-3 py-2">
                      <div class="flex items-center gap-2">
                        <span class:list={['size-2 rounded-full', toneClasses[signal.tone]]} style="background: currentColor"></span>
                        <span class="text-sm text-muted">{signal.label}</span>
                      </div>
                      <div class="flex items-baseline gap-2">
                        <span class="metric-value text-lg font-semibold">{signal.value}</span>
                        <span class:list={['text-xs', toneClasses[signal.tone]]}>{signal.trend}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </section>

              <section class="panel rounded-lg p-4">
                <div class="mb-4 flex items-center justify-between">
                  <div>
                    <h2 class="text-base font-semibold">Budget pressure</h2>
                    <p class="mt-1 text-sm text-muted">Last 12 intervals.</p>
                  </div>
                  <AlertTriangle size={20} class="text-warning" />
                </div>
                <div class="flex h-36 items-end gap-2 rounded-lg border border-border/60 bg-bg-raised p-3">
                  {budgetSeries.map((value) => (
                    <div class="flex flex-1 items-end">
                      <div
                        class="w-full rounded-t bg-accent/80"
                        style={`height: ${(value / maxBudget) * 100}%`}
                        title={`${value}%`}
                      ></div>
                    </div>
                  ))}
                </div>
              </section>
            </aside>
          </section>

          <section class="mt-4 grid gap-4 xl:grid-cols-[minmax(0,1fr)_420px]">
            <div class="panel overflow-hidden rounded-lg">
              <div class="flex items-center justify-between border-b border-border/70 p-4">
                <div>
                  <h2 class="text-base font-semibold">Model matrix</h2>
                  <p class="mt-1 text-sm text-muted">Capability, reliability, cost and latency in one scan.</p>
                </div>
                <BrainCircuit size={20} class="text-accent" />
              </div>
              <div class="scrollbar-subtle overflow-x-auto">
                <table class="w-full min-w-[820px] text-sm">
                  <thead class="bg-bg-raised/70 text-xs uppercase text-faint">
                    <tr>
                      <th class="px-4 py-3 text-start font-medium">Model</th>
                      <th class="px-4 py-3 text-start font-medium">Tier</th>
                      <th class="px-4 py-3 text-start font-medium">Cost</th>
                      <th class="px-4 py-3 text-start font-medium">p50</th>
                      <th class="px-4 py-3 text-start font-medium">p95</th>
                      <th class="px-4 py-3 text-start font-medium">Success</th>
                      <th class="px-4 py-3 text-start font-medium">Capabilities</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-border/60">
                    {modelMatrix.map((model) => (
                      <tr class="hover:bg-surface-2/70">
                        <td class="px-4 py-3">
                          <div class="font-medium text-text">{model.model}</div>
                          <div class="text-xs text-muted">{model.provider}</div>
                        </td>
                        <td class="metric-value px-4 py-3">{model.tier}</td>
                        <td class="metric-value px-4 py-3">{model.cost}</td>
                        <td class="metric-value px-4 py-3 text-muted">{model.p50}</td>
                        <td class="metric-value px-4 py-3 text-muted">{model.p95}</td>
                        <td class="px-4 py-3">
                          <span class="chip border-success/35 bg-success/8 text-success">{model.success}</span>
                        </td>
                        <td class="px-4 py-3">
                          <div class="flex flex-wrap gap-1.5">
                            {model.caps.map((cap) => <span class="chip border-border bg-bg-raised text-muted">{cap}</span>)}
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="panel rounded-lg p-4">
              <div class="mb-4 flex items-center justify-between">
                <div>
                  <h2 class="text-base font-semibold">Projects</h2>
                  <p class="mt-1 text-sm text-muted">Spend and local/cloud split.</p>
                </div>
                <LockKeyhole size={20} class="text-accent" />
              </div>
              <div class="grid gap-2">
                {projectRows.map((project) => (
                  <article class="rounded-lg border border-border/60 bg-bg-raised p-3">
                    <div class="flex items-center justify-between">
                      <h3 class="text-sm font-semibold">{project.name}</h3>
                      <span class="metric-value text-sm text-muted">{project.spend}</span>
                    </div>
                    <div class="mt-3 grid grid-cols-3 gap-2 text-xs">
                      <div>
                        <div class="text-faint">Requests</div>
                        <div class="metric-value mt-1 text-sm text-text">{project.requests}</div>
                      </div>
                      <div>
                        <div class="text-faint">Local</div>
                        <div class="metric-value mt-1 text-sm text-success">{project.local}</div>
                      </div>
                      <div>
                        <div class="text-faint">Rejects</div>
                        <div class="metric-value mt-1 text-sm text-warning">{project.rejects}</div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        </div>
      </main>
    </div>

    <div id="inspector" class="pointer-events-none fixed inset-0 z-30 hidden bg-bg/45 opacity-0 transition duration-200" aria-hidden="true">
      <button id="inspector-backdrop" class="absolute inset-0 cursor-default" aria-label="Close request inspector"></button>
      <aside class="absolute end-0 top-0 flex h-full w-full max-w-[440px] translate-x-6 flex-col border-s border-border bg-bg-raised shadow-2xl transition duration-200">
        <div class="border-b border-border p-4">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-xs uppercase text-faint">Request inspector</p>
              <h2 id="drawer-title" class="mt-1 text-lg font-semibold">Route decision</h2>
            </div>
            <button id="inspector-close" class="focus-ring inline-flex size-9 items-center justify-center rounded-lg border border-border bg-surface text-muted hover:text-text" aria-label="Close request inspector">
              ×
            </button>
          </div>
        </div>
        <div class="scrollbar-subtle flex-1 overflow-y-auto p-4">
          <div class="grid gap-3">
            <div class="rounded-lg border border-border bg-surface p-3">
              <div class="text-xs uppercase text-faint">Selected model</div>
              <div id="drawer-model" class="mt-2 text-base font-semibold"></div>
            </div>
            <div class="grid grid-cols-3 gap-2">
              <div class="rounded-lg border border-border bg-surface p-3">
                <div class="text-xs text-faint">Cost</div>
                <div id="drawer-cost" class="metric-value mt-2"></div>
              </div>
              <div class="rounded-lg border border-border bg-surface p-3">
                <div class="text-xs text-faint">Latency</div>
                <div id="drawer-latency" class="metric-value mt-2"></div>
              </div>
              <div class="rounded-lg border border-border bg-surface p-3">
                <div class="text-xs text-faint">Tier</div>
                <div id="drawer-tier" class="metric-value mt-2"></div>
              </div>
            </div>
            <div class="rounded-lg border border-border bg-surface p-3">
              <div class="mb-3 flex items-center gap-2 text-sm font-medium">
                <CheckCircle2 size={16} class="text-success" />
                Decision path
              </div>
              <ol class="grid gap-2 text-sm text-muted">
                <li class="rounded-md bg-bg-raised p-2">Input tokens estimated and task classified.</li>
                <li class="rounded-md bg-bg-raised p-2">Policy constraints applied before provider forwarding.</li>
                <li id="drawer-reason" class="rounded-md bg-bg-raised p-2"></li>
              </ol>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <script>
      const inspector = document.querySelector('#inspector');
      const closeButton = document.querySelector('#inspector-close');
      const backdrop = document.querySelector('#inspector-backdrop');
      const fields = {
        title: document.querySelector('#drawer-title'),
        model: document.querySelector('#drawer-model'),
        cost: document.querySelector('#drawer-cost'),
        latency: document.querySelector('#drawer-latency'),
        tier: document.querySelector('#drawer-tier'),
        reason: document.querySelector('#drawer-reason'),
      };

      function openInspector(row) {
        const data = JSON.parse(row.dataset.request || '{}');
        fields.title.textContent = `${data.task || 'request'} · ${data.status || 'unknown'}`;
        fields.model.textContent = data.model || '-';
        fields.cost.textContent = data.cost || '-';
        fields.latency.textContent = data.latency || '-';
        fields.tier.textContent = data.tier ? String(data.tier) : '-';
        fields.reason.textContent = data.reason || 'No routing reason recorded.';
        inspector.classList.remove('hidden');
        requestAnimationFrame(() => {
          inspector.classList.remove('pointer-events-none', 'opacity-0');
          inspector.querySelector('aside').classList.remove('translate-x-6');
          inspector.setAttribute('aria-hidden', 'false');
        });
      }

      function closeInspector() {
        inspector.classList.add('pointer-events-none', 'opacity-0');
        inspector.querySelector('aside').classList.add('translate-x-6');
        inspector.setAttribute('aria-hidden', 'true');
        window.setTimeout(() => inspector.classList.add('hidden'), 200);
      }

      document.querySelectorAll('[data-request-row]').forEach((row) => {
        row.addEventListener('click', (event) => {
          if (event.target.closest('button') || event.currentTarget === row) {
            openInspector(row);
          }
        });
      });
      closeButton.addEventListener('click', closeInspector);
      backdrop.addEventListener('click', closeInspector);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && inspector.getAttribute('aria-hidden') === 'false') {
          closeInspector();
        }
      });
    </script>
  </body>
</html>
